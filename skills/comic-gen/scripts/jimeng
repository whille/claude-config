#!/usr/bin/env python3
"""
即梦 CLI - 火山方舟文生图命令行工具

支持模型: Doubao-Seedream-4.5 (推荐) / Doubao-Seedream-3.0
支持角色一致性: 通过参考图绑定角色形象

Usage:
    jimeng init              # 配置 API Key
    jimeng generate <prompt> # 生成图片
    jimeng batch <file>      # 批量生成
    jimeng series <prompt>   # 组图生成 (Seedream 4.5 特有)
    jimeng config            # 显示当前配置
"""

import os
import sys
import json
import base64
import argparse
from pathlib import Path
from datetime import datetime

# 配置文件路径
CONFIG_DIR = Path.home() / ".jimeng"
CONFIG_FILE = CONFIG_DIR / "config.json"
OUTPUT_DIR = CONFIG_DIR / "output"
REFERENCE_DIR = CONFIG_DIR / "references"

# 支持的模型
MODELS = {
    "4.5": "Doubao-Seedream-4.5-t2i (推荐: 2K/4K, 组图生成, 多图融合)",
    "3.0": "Doubao-Seedream-3.0-t2i (基础版: 1280x720)",
}

# 支持的尺寸
SIZES = {
    "720p": "1280x720",
    "1080p": "1920x1080",
    "2k": "2560x1440",
    "4k": "3840x2160",
    "1:1": "1024x1024",
    "16:9": "1920x1080",
    "9:16": "1080x1920",
    "3:4": "1536x2048",
    "4:3": "2048x1536",
}

def load_config():
    """加载配置"""
    if not CONFIG_FILE.exists():
        return None
    try:
        with open(CONFIG_FILE, 'r') as f:
            return json.load(f)
    except:
        return None

def save_config(config):
    """保存配置"""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_FILE, 'w') as f:
        json.dump(config, f, indent=2, ensure_ascii=False)
    print(f"✅ 配置已保存到 {CONFIG_FILE}")

def check_dependencies():
    """检查依赖"""
    try:
        from openai import OpenAI
        return True
    except ImportError:
        print("❌ 缺少依赖: openai")
        print("请运行: pip install openai")
        return False

def load_reference_image(reference_path):
    """加载参考图片并转为 data URI"""
    ref_path = Path(reference_path)
    if not ref_path.exists():
        print(f"❌ 参考图不存在: {ref_path}")
        return None

    # 检查文件类型
    if ref_path.suffix.lower() not in ['.jpg', '.jpeg', '.png', '.webp']:
        print(f"❌ 不支持的图片格式: {ref_path.suffix}")
        return None

    # 读取并编码为 data URI
    try:
        with open(ref_path, 'rb') as f:
            image_data = f.read()
        mime_type = "image/jpeg" if ref_path.suffix.lower() in ['.jpg', '.jpeg'] else f"image/{ref_path.suffix[1:]}"
        base64_data = base64.b64encode(image_data).decode('utf-8')
        return f"data:{mime_type};base64,{base64_data}"
    except Exception as e:
        print(f"❌ 读取参考图失败: {e}")
        return None

def save_reference_image(image_path, name):
    """保存参考图到 references 目录"""
    REFERENCE_DIR.mkdir(parents=True, exist_ok=True)
    src_path = Path(image_path)
    if not src_path.exists():
        print(f"❌ 图片不存在: {src_path}")
        return None

    # 复制到 references 目录
    import shutil
    dest_path = REFERENCE_DIR / f"{name}{src_path.suffix}"
    shutil.copy(src_path, dest_path)
    print(f"✅ 参考图已保存: {dest_path}")
    return dest_path

def cmd_init(args):
    """初始化配置"""
    print("🔧 即梦 CLI 配置向导")
    print()
    print("请访问火山方舟控制台获取配置信息:")
    print("  1. 控制台: https://console.volcengine.com/ark")
    print("  2. 创建 API Key: API Key管理 → 创建 API Key")
    print("  3. 创建接入点: 在线推理 → 创建推理接入点")
    print()

    # 选择模型版本
    print("选择模型版本:")
    for key, desc in MODELS.items():
        print(f"  [{key}] {desc}")
    print()

    model_version = input("模型版本 (默认 4.5): ").strip() or "4.5"
    if model_version not in MODELS:
        print(f"⚠️ 未知版本，使用默认 4.5")
        model_version = "4.5"

    api_key = input("请输入 API Key: ").strip()
    if not api_key:
        print("❌ API Key 不能为空")
        return

    endpoint_id = input("请输入推理接入点 ID: ").strip()
    if not endpoint_id:
        print("❌ 接入点 ID 不能为空")
        return

    config = {
        "api_key": api_key,
        "endpoint_id": endpoint_id,
        "model_version": model_version,
        "base_url": "https://ark.cn-beijing.volces.com/api/v3",
        "output_dir": str(OUTPUT_DIR)
    }

    save_config(config)
    print()
    print("✅ 配置完成!")
    print(f"   API Key: {api_key[:8]}...")
    print(f"   接入点: {endpoint_id[:16]}...")
    print(f"   模型: {MODELS[model_version].split('(')[0].strip()}")

def cmd_generate(args):
    """生成图片"""
    config = load_config()
    if not config:
        print("❌ 未配置，请先运行: jimeng init")
        return

    if not check_dependencies():
        return

    from openai import OpenAI

    client = OpenAI(
        base_url=config["base_url"],
        api_key=config["api_key"],
    )

    prompt = args.prompt
    output_dir = Path(config.get("output_dir", OUTPUT_DIR))
    output_dir.mkdir(parents=True, exist_ok=True)

    # 解析尺寸
    size = SIZES.get(args.size, args.size)

    # 生成文件名
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    prefix = args.prefix or f"jimeng_{timestamp}"
    output_file = output_dir / f"{prefix}.jpg"

    # 构建请求参数
    extra_body = {"watermark": False}

    # 处理参考图（角色一致性）
    image_url = None
    if args.reference:
        image_url = load_reference_image(args.reference)
        if not image_url:
            return
        print(f"📐 使用参考图: {args.reference}")
        print(f"   参考强度: {args.strength}")

    print(f"🎨 生成图片 (模型: {config.get('model_version', '4.5')})")
    print(f"   尺寸: {size}")
    print(f"   Prompt: {prompt[:60]}..." if len(prompt) > 60 else f"   Prompt: {prompt}")

    try:
        # 构建请求参数
        extra_body = {"watermark": False}

        # 添加参考图（通过 extra_body）
        if image_url:
            extra_body["image_url"] = image_url
            extra_body["strength"] = args.strength

        response = client.images.generate(
            model=config["endpoint_id"],
            prompt=prompt,
            size=size,
            response_format="b64_json",
            extra_body=extra_body
        )

        # 保存图片
        image_data = base64.b64decode(response.data[0].b64_json)
        with open(output_file, 'wb') as f:
            f.write(image_data)

        print(f"✅ 图片已保存: {output_file}")

        # 如果是首图，提示可以保存为参考图
        if args.save_reference:
            save_reference_image(output_file, args.save_reference)

    except Exception as e:
        print(f"❌ 生成失败: {e}")

def cmd_series(args):
    """组图生成 (Seedream 4.5 特有)"""
    config = load_config()
    if not config:
        print("❌ 未配置，请先运行: jimeng init")
        return

    model_version = config.get("model_version", "4.5")
    if model_version != "4.5":
        print("⚠️ 组图生成需要 Doubao-Seedream-4.5 模型")
        print("   请重新运行 jimeng init 选择 4.5 版本")
        return

    if not check_dependencies():
        return

    from openai import OpenAI

    client = OpenAI(
        base_url=config["base_url"],
        api_key=config["api_key"],
    )

    prompt = args.prompt
    output_dir = Path(config.get("output_dir", OUTPUT_DIR))
    output_dir.mkdir(parents=True, exist_ok=True)

    count = args.count
    mode = args.mode

    # 构建请求参数
    extra_body = {
        "watermark": False,
        "gen_mode": mode,  # auto / story_book / comic_strip
    }

    # 处理参考图（角色一致性）
    image_url = None
    if args.reference:
        image_url = load_reference_image(args.reference)
        if not image_url:
            return
        print(f"📐 使用参考图: {args.reference}")
        print(f"   参考强度: {args.strength}")

    print(f"🎨 组图生成 (Seedream 4.5)")
    print(f"   模式: {mode}")
    print(f"   数量: {count} 张")
    print(f"   Prompt: {prompt[:60]}..." if len(prompt) > 60 else f"   Prompt: {prompt}")

    try:
        # 构建请求参数
        extra_body = {
            "watermark": False,
            "gen_mode": mode,
        }

        # 添加参考图
        if image_url:
            extra_body["image_url"] = image_url
            extra_body["strength"] = args.strength

        response = client.images.generate(
            model=config["endpoint_id"],
            prompt=prompt,
            size="2560x1440",
            n=count,
            response_format="b64_json",
            extra_body=extra_body
        )

        # 保存图片
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        prefix = args.prefix or f"series_{timestamp}"

        for i, img_data in enumerate(response.data, 1):
            image_data = base64.b64decode(img_data.b64_json)
            output_file = output_dir / f"{prefix}_{i:02d}.jpg"
            with open(output_file, 'wb') as f:
                f.write(image_data)
            print(f"  ✅ [{i}/{count}] {output_file}")

        print(f"\n✅ 组图已保存到: {output_dir}")

    except Exception as e:
        print(f"❌ 生成失败: {e}")

def cmd_batch(args):
    """批量生成"""
    config = load_config()
    if not config:
        print("❌ 未配置，请先运行: jimeng init")
        return

    if not check_dependencies():
        return

    from openai import OpenAI
    import concurrent.futures

    # 读取 Prompt 文件
    prompt_file = Path(args.file)
    if not prompt_file.exists():
        print(f"❌ 文件不存在: {prompt_file}")
        return

    with open(prompt_file, 'r', encoding='utf-8') as f:
        prompts = [line.strip() for line in f if line.strip()]

    print(f"📋 读取到 {len(prompts)} 条 Prompt")

    client = OpenAI(
        base_url=config["base_url"],
        api_key=config["api_key"],
    )

    output_dir = Path(config.get("output_dir", OUTPUT_DIR))
    output_dir.mkdir(parents=True, exist_ok=True)

    size = SIZES.get(args.size, args.size)

    # 加载参考图（如果指定）
    image_url = None
    if args.reference:
        image_url = load_reference_image(args.reference)
        if image_url:
            print(f"📐 使用参考图: {args.reference}")
            print(f"   参考强度: {args.strength}")

    def generate_one(index, prompt):
        try:
            extra_body = {"watermark": False}
            if image_url:
                extra_body["image_url"] = image_url
                extra_body["strength"] = args.strength

            response = client.images.generate(
                model=config["endpoint_id"],
                prompt=prompt,
                size=size,
                response_format="b64_json",
                extra_body=extra_body
            )
            image_data = base64.b64decode(response.data[0].b64_json)
            output_file = output_dir / f"{args.prefix}_{index:03d}.jpg"
            with open(output_file, 'wb') as f:
                f.write(image_data)
            return True, output_file
        except Exception as e:
            return False, str(e)

    print(f"🎨 批量生成中...")
    success_count = 0

    with concurrent.futures.ThreadPoolExecutor(max_workers=args.workers) as executor:
        futures = {
            executor.submit(generate_one, i, p): (i, p)
            for i, p in enumerate(prompts, 1)
        }
        for future in concurrent.futures.as_completed(futures):
            i, p = futures[future]
            success, result = future.result()
            if success:
                print(f"  ✅ [{i}/{len(prompts)}] {result}")
                success_count += 1
            else:
                print(f"  ❌ [{i}/{len(prompts)}] {result}")

    print(f"\n✅ 完成: {success_count}/{len(prompts)} 成功")
    print(f"   输出目录: {output_dir}")

def cmd_reference(args):
    """管理参考图"""
    REFERENCE_DIR.mkdir(parents=True, exist_ok=True)

    if args.action == "list":
        print("📋 已保存的参考图:")
        for f in REFERENCE_DIR.glob("*"):
            if f.is_file():
                print(f"   - {f.stem}: {f}")

    elif args.action == "add":
        if not args.file:
            print("❌ 请指定图片文件: -f <图片路径>")
            return
        if not args.name:
            print("❌ 请指定参考图名称: -n <名称>")
            return
        save_reference_image(args.file, args.name)

    elif args.action == "remove":
        if not args.name:
            print("❌ 请指定参考图名称: -n <名称>")
            return
        for f in REFERENCE_DIR.glob(f"{args.name}.*"):
            f.unlink()
            print(f"✅ 已删除: {f}")

def cmd_config(args):
    """显示配置"""
    config = load_config()
    if not config:
        print("❌ 未配置，请先运行: jimeng init")
        return

    print("📋 当前配置:")
    print(f"   API Key: {config['api_key'][:8]}...")
    print(f"   接入点: {config['endpoint_id'][:16]}...")
    print(f"   模型版本: {config.get('model_version', '4.5')}")
    print(f"   Base URL: {config['base_url']}")
    print(f"   输出目录: {config.get('output_dir', OUTPUT_DIR)}")
    print(f"   参考图目录: {REFERENCE_DIR}")

def main():
    parser = argparse.ArgumentParser(
        description="即梦 CLI - 火山方舟文生图工具 (支持 Doubao-Seedream-4.5，角色一致性)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  jimeng init                          # 初始化配置
  jimeng generate "一只可爱的猫咪"       # 生成图片
  jimeng generate "林黛玉" -s 2k        # 2K 分辨率

  # 角色一致性（使用参考图）
  jimeng generate "贾宝玉在怡红院" -r baoyu.jpg -t 0.8
  jimeng batch prompts.txt -r baoyu.jpg -t 0.7 -p hongloumeng

  # 组图生成（4.5 特有）
  jimeng series "红楼梦场景" -c 5 -m comic_strip
  jimeng series "林黛玉葬花" -c 10 -r daiyu.jpg -t 0.8

  # 参考图管理
  jimeng reference list                # 列出已保存的参考图
  jimeng reference add -f image.jpg -n baoyu  # 保存参考图
  jimeng reference remove -n baoyu     # 删除参考图

支持的尺寸:
  720p, 1080p, 2k, 4k, 1:1, 16:9, 9:16, 3:4, 4:3

Seedream 4.5 特性:
  - 2K/4K 高分辨率输出
  - 组图生成 (一次最多 15 张)
  - 多图融合 (最多 8 张参考图)
  - 精准保持原图风格
  - 角色一致性绑定 (-r 参数)

参数说明:
  -r, --reference  参考图路径（用于角色一致性）
  -t, --strength   参考强度 0.0-1.0（默认: 0.8，值越大越接近参考图）
"""
    )

    subparsers = parser.add_subparsers(dest="command", help="命令")

    # init
    parser_init = subparsers.add_parser("init", help="初始化配置")

    # generate
    parser_gen = subparsers.add_parser("generate", help="生成单张图片")
    parser_gen.add_argument("prompt", help="图片描述")
    parser_gen.add_argument("-s", "--size", default="2k", help="图片尺寸 (默认: 2k)")
    parser_gen.add_argument("-p", "--prefix", help="输出文件名前缀")
    parser_gen.add_argument("-r", "--reference", help="参考图路径（角色一致性）")
    parser_gen.add_argument("-t", "--strength", type=float, default=0.8,
                           help="参考强度 0.0-1.0 (默认: 0.8)")
    parser_gen.add_argument("--save-reference", metavar="NAME", help="保存为参考图")

    # series (Seedream 4.5)
    parser_series = subparsers.add_parser("series", help="组图生成 (4.5 特有)")
    parser_series.add_argument("prompt", help="图片描述")
    parser_series.add_argument("-c", "--count", type=int, default=5, help="生成数量 (默认: 5)")
    parser_series.add_argument("-m", "--mode", default="auto", choices=["auto", "story_book", "comic_strip"],
                               help="生成模式: auto/story_book/comic_strip")
    parser_series.add_argument("-p", "--prefix", help="输出文件名前缀")
    parser_series.add_argument("-r", "--reference", help="参考图路径（角色一致性）")
    parser_series.add_argument("-t", "--strength", type=float, default=0.8,
                               help="参考强度 0.0-1.0 (默认: 0.8)")

    # batch
    parser_batch = subparsers.add_parser("batch", help="批量生成")
    parser_batch.add_argument("file", help="Prompt 文件 (每行一条)")
    parser_batch.add_argument("-p", "--prefix", default="batch", help="输出文件名前缀")
    parser_batch.add_argument("-s", "--size", default="2k", help="图片尺寸")
    parser_batch.add_argument("-w", "--workers", type=int, default=3, help="并发数 (默认: 3)")
    parser_batch.add_argument("-r", "--reference", help="参考图路径（角色一致性）")
    parser_batch.add_argument("-t", "--strength", type=float, default=0.8,
                               help="参考强度 0.0-1.0 (默认: 0.8)")

    # reference
    parser_ref = subparsers.add_parser("reference", help="管理参考图")
    parser_ref.add_argument("action", choices=["list", "add", "remove"], help="操作: list/add/remove")
    parser_ref.add_argument("-f", "--file", help="图片文件路径")
    parser_ref.add_argument("-n", "--name", help="参考图名称")

    # config
    parser_config = subparsers.add_parser("config", help="显示配置")

    args = parser.parse_args()

    if args.command == "init":
        cmd_init(args)
    elif args.command == "generate":
        cmd_generate(args)
    elif args.command == "series":
        cmd_series(args)
    elif args.command == "batch":
        cmd_batch(args)
    elif args.command == "reference":
        cmd_reference(args)
    elif args.command == "config":
        cmd_config(args)
    else:
        parser.print_help()

if __name__ == "__main__":
    main()
